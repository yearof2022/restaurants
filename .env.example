# Copy this file to .env and paste your real keys.

# --- LocationIQ (geocoding) ---
# Get a free key (5,000/day, no credit card) at https://locationiq.com/register
LOCATIONIQ_API_KEY=your_key_here

# --- Notion (optional — only needed for sync_notion.py) ---
# Create an Internal Integration at https://www.notion.so/profile/integrations
# Then share your restaurants database with it (DB → … → Connections).
NOTION_TOKEN=ntn_xxxxxxxxxxxx
NOTION_DATABASE_ID=193b17183004802f8ab0d1f5ca29ebfd

# --- Misc ---
# SSL verify is disabled by default to work around Python 3.14 + OpenSSL
# strictness in some environments. Set to 1 if your CA chain is clean.
VERIFY_SSL=0
